# Multi-stage container for the Neural MoE demo (demo_moe.py).
# CPU-only PyTorch keeps the image small; no GPU is required.
#
# Build:  docker build -t rescue-sim-moe -f Dockerfile_moe .
# Run:    docker run --rm -it rescue-sim-moe

# ── Stage 1: builder — install the package + dependencies into a venv ────
FROM python:3.12-slim AS builder

WORKDIR /build

COPY pyproject.toml ./
COPY src/ ./src/

RUN python -m venv /opt/venv && \
    /opt/venv/bin/pip install --no-cache-dir --upgrade pip && \
    /opt/venv/bin/pip install --no-cache-dir ".[dev]" && \
    /opt/venv/bin/pip install --no-cache-dir torch --index-url https://download.pytorch.org/whl/cpu

# ── Stage 2: runner — copy only the venv and what the demo needs ─────────
FROM python:3.12-slim AS runner

ENV PYTHONDONTWRITEBYTECODE=1 \
    PYTHONUNBUFFERED=1 \
    PATH="/opt/venv/bin:$PATH"

WORKDIR /app

COPY --from=builder /opt/venv /opt/venv

# Source, tests (the demo ends with a pytest integration gate), and entrypoint
COPY src/ ./src/
COPY tests/ ./tests/
COPY pyproject.toml demo_moe.py ./

ENTRYPOINT ["python", "demo_moe.py"]
